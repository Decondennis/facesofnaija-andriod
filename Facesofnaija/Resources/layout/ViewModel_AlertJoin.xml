<?xml version="1.0" encoding="utf-8"?>
<!-- Community / Announcement Card — MaterialCardView with icon, marquee text, action button -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="false">

    <RelativeLayout
        android:id="@+id/mainview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/Shape_Community_Bg"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:padding="14dp">

        <!-- Circular badge icon (top-left) -->
        <ImageView
            android:id="@+id/IconImageview"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@drawable/circle_white"
            android:src="@drawable/sharegroup"
            android:scaleType="centerInside"
            android:padding="6dp" />

        <!-- Decorative illustration (top-right) -->
        <ImageView
            android:id="@+id/Imageview"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/Image2"
            android:scaleType="centerCrop"
            android:alpha="0.85" />

        <!-- Title (e.g. "Communities" or "Breaking News") -->
        <TextView
            android:id="@+id/HeadText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/IconImageview"
            android:layout_toStartOf="@id/Imageview"
            android:layout_alignTop="@id/IconImageview"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="8dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"
            android:clickable="false"
            android:focusable="false" />

        <!-- Scrolling marquee subtitle -->
        <TextView
            android:id="@+id/subText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/IconImageview"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            android:textColor="#FFFDE7"
            android:textSize="13sp"
            android:singleLine="true"
            android:scrollHorizontally="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="false" />

        <!-- Action button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonview"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_below="@id/subText"
            android:layout_alignParentStart="true"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="2dp"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:textColor="#388E3C"
            android:text="@string/Lbl_FindYourGroups"
            android:backgroundTint="#FFFFFF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>