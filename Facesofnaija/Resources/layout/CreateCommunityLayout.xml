<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:background="?attr/colorFill"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
                app:theme="@style/ToolbarTheme"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            app:titleTextAppearance="@style/Toolbar.TitleText"
            android:background="?attr/colorFill">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Lbl_Submit"
                android:layout_gravity="end"
                android:textSize="15sp"
                android:textStyle="bold"
                android:padding="15dp" 
                android:id="@+id/toolbar_title" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbar"
        android:clipToPadding="false"
        android:padding="20dp"
        android:scrollbars="none"
        android:scrollingCache="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
	                     
			<!--Name Section -->
			<LinearLayout
				android:id="@+id/LayoutName"
				android:paddingTop="5dp"
				android:layout_marginTop="5dp"
				android:layout_marginEnd="5dp"
				android:layout_width="match_parent"
				android:orientation="horizontal"
				android:layout_height="wrap_content">
				<EditText
					android:id="@+id/NameText"
					style="@style/EditTextNormalStyle"
					android:layout_width="match_parent"
					android:layout_height="45dp"
					android:hint="@string/Lbl_CommunityName"
					android:textSize="15sp"
					android:gravity="start|center"
					android:background="@drawable/round_gray_border"
					android:layout_alignParentEnd="true"
					android:layout_marginStart="3dp" />
			</LinearLayout>
	          
	        <!--Country Section -->
	        <LinearLayout
		        android:id="@+id/LayoutTitle"
		        android:paddingTop="5dp"
		        android:layout_marginTop="5dp"
		        android:layout_marginEnd="5dp"
		        android:layout_width="match_parent"
		        android:orientation="horizontal"
		        android:layout_height="wrap_content">
		        <EditText
			        android:id="@+id/CountryText"
					android:inputType="text"
			        style="@style/EditTextNormalStyle"
			        android:layout_width="match_parent"
			        android:layout_height="45dp"
			        android:hint="@string/Lbl_Country"
			        android:textSize="15sp"
			        android:gravity="start|center"
			        android:background="@drawable/round_gray_border"
			        android:layout_alignParentEnd="true"
			        android:layout_marginStart="3dp" />
	        </LinearLayout>
             
	        <!--State Section -->
	        <LinearLayout
		        android:id="@+id/LayoutState"
		        android:paddingTop="5dp"
		        android:layout_marginTop="5dp"
		        android:layout_marginEnd="5dp"
		        android:layout_width="match_parent"
		        android:orientation="horizontal"
		        android:layout_height="wrap_content">
		        <EditText
			        android:id="@+id/StateText"
					android:inputType="text"
			        style="@style/EditTextNormalStyle"
			        android:layout_width="match_parent"
			        android:layout_height="45dp"
			        android:hint="@string/Lbl_State"
			        android:textSize="15sp"
			        android:gravity="start|center"
			        android:background="@drawable/round_gray_border"
			        android:layout_alignParentEnd="true"
			        android:layout_marginStart="3dp" />
	        </LinearLayout>
             
	        <!--Lga Section -->
	        <LinearLayout
		        android:id="@+id/LayoutLga"
		        android:paddingTop="5dp"
		        android:layout_marginTop="5dp"
		        android:layout_marginEnd="5dp"
		        android:layout_width="match_parent"
		        android:orientation="horizontal"
		        android:layout_height="wrap_content">
		        <EditText
			        android:id="@+id/LgaText"
					android:inputType="text"
			        style="@style/EditTextNormalStyle"
			        android:layout_width="match_parent"
			        android:layout_height="45dp"
			        android:hint="@string/Lbl_Lga"
			        android:textSize="15sp"
			        android:gravity="start|center"
			        android:background="@drawable/round_gray_border"
			        android:layout_alignParentEnd="true"
			        android:layout_marginStart="3dp" />
	        </LinearLayout>

	        <!--Description Section -->
	        <LinearLayout
		        android:id="@+id/LayoutDescription"
		        android:paddingTop="5dp"
		        android:layout_marginTop="5dp"
		        android:layout_marginEnd="5dp"
		        android:layout_width="match_parent"
		        android:orientation="horizontal"
		        android:layout_height="wrap_content">
		        <EditText
			        android:id="@+id/DescriptionText"
					android:inputType="text"
			        style="@style/EditTextNormalStyle"
			        android:layout_width="match_parent"
			        android:layout_height="80dp"
			        android:background="@drawable/round_gray_border"
			        android:hint="@string/Lbl_Describe_Community"
			        android:textSize="15sp"
			        android:gravity="start"
			        android:layout_alignParentEnd="true"
			        android:layout_marginStart="3dp" />
	        </LinearLayout>

	        <!--Privacy Section -->
	        <LinearLayout
		        android:id="@+id/LayoutGender"
		        android:paddingTop="5dp"
		        android:layout_marginTop="5dp"
		        android:layout_marginEnd="5dp"
		        android:layout_width="match_parent"
		        android:orientation="horizontal"
		        android:layout_height="wrap_content">
		        <EditText
			        android:id="@+id/PrivacyText"
					android:inputType="text"
			        style="@style/EditTextNormalStyle"
			        android:layout_width="match_parent"
			        android:layout_height="45dp"
			        android:hint="@string/Lbl_Privacy"
			        android:textSize="15sp"
			        android:gravity="start|center"
			        android:background="@drawable/round_gray_border"
			        android:layout_alignParentEnd="true"
			        android:layout_marginStart="3dp" />
	        </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>