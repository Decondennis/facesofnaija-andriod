<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f0f2f5"
    android:scrollbars="vertical">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/brand_green"
            android:paddingTop="50dp"
            android:paddingBottom="40dp"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"
            android:gravity="center_horizontal">
            <ImageView
                android:id="@+id/Logoplace"
                android:layout_width="180dp"
                android:layout_height="80dp"
                android:src="@drawable/logo"
                android:scaleType="fitCenter" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/welcome_title"
                android:textColor="@color/gnt_white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center_horizontal"
                android:layout_marginTop="20dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/register_description"
                android:textColor="#D0FFFFFF"
                android:textSize="15sp"
                android:gravity="center_horizontal"
                android:layout_marginTop="8dp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_dialog"
            android:padding="24dp"
            android:layout_marginTop="-20dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Lbl_Register"
                android:gravity="center_horizontal"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/brand_green" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/register_description"
                android:gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:textSize="13sp"
                android:textColor="#888888" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Lbl_Username"
                android:layout_marginTop="16dp"
                android:textSize="14sp"
                android:textColor="#44000000" />
            <EditText
                android:id="@+id/UsernameEditText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/EditTextStyleOne"
                style="@style/EditTextNormalStyle"
                android:layout_marginTop="4dp"
                android:hint="@string/Lbl_Username"
                android:textSize="14sp"
                android:inputType="text" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Lbl_Email"
                android:layout_marginTop="14dp"
                android:textSize="14sp"
                android:textColor="#44000000" />
            <EditText
                android:id="@+id/EmailEditText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/EditTextStyleOne"
                style="@style/EditTextNormalStyle"
                android:layout_marginTop="4dp"
                android:hint="@string/Lbl_YourEmail"
                android:textSize="14sp"
                android:inputType="textEmailAddress" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Lbl_Password"
                android:layout_marginTop="14dp"
                android:textSize="14sp"
                android:textColor="#44000000" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">
                <EditText
                    android:id="@+id/PasswordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/EditTextStyleOne"
                    style="@style/EditTextNormalStyle"
                    android:hint="@string/Lbl_Password"
                    android:paddingEnd="50dp"
                    android:textSize="14sp"
                    android:inputType="textPassword" />
                <ImageView
                    android:id="@+id/imageShowPass"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/icon_eyes_vector"
                    android:tint="#808183"
                    android:layout_marginEnd="16dp"
                    android:layout_gravity="end|center" />
            </FrameLayout>
            <LinearLayout
                android:id="@+id/passwordHelper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp"
                android:paddingStart="4dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/helperLength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pw_helper_length"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/helperLowercase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pw_helper_lowercase"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/helperUppercase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pw_helper_uppercase"
                    android:textSize="12sp"
                    android:textColor="#888888" />
                <TextView
                    android:id="@+id/helperSpecial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/pw_helper_special"
                    android:textSize="12sp"
                    android:textColor="#888888" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Lbl_ConfirmPassword"
                android:layout_marginTop="14dp"
                android:textSize="14sp"
                android:textColor="#44000000" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">
                <EditText
                    android:id="@+id/ConfirmPasswordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/EditTextStyleOne"
                    style="@style/EditTextNormalStyle"
                    android:hint="@string/Lbl_ConfirmPassword"
                    android:paddingEnd="50dp"
                    android:textSize="14sp"
                    android:inputType="textPassword" />
                <ImageView
                    android:id="@+id/imageShowConPass"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/icon_eyes_vector"
                    android:tint="#808183"
                    android:layout_marginEnd="16dp"
                    android:layout_gravity="end|center" />
            </FrameLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Lbl_Gender"
                android:layout_marginTop="14dp"
                android:textSize="14sp"
                android:textColor="#44000000" />
            <EditText
                android:id="@+id/GenderEditText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/EditTextStyleOne"
                style="@style/EditTextNormalStyle"
                android:layout_marginTop="4dp"
                android:hint="@string/Lbl_Gender"
                android:textSize="14sp"
                android:inputType="text" />
            <LinearLayout
                android:id="@+id/BirthdayLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/Lbl_Birthday"
                    android:layout_marginTop="14dp"
                    android:textSize="14sp"
                    android:textColor="#44000000" />
                <EditText
                    android:id="@+id/BirthdayEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/EditTextStyleOne"
                    style="@style/EditTextNormalStyle"
                    android:layout_marginTop="4dp"
                    android:hint="@string/Lbl_Birthday"
                    android:textSize="14sp"
                    android:inputType="text" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/PhoneNumLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/Lbl_Phone"
                    android:layout_marginTop="14dp"
                    android:textSize="14sp"
                    android:textColor="#44000000" />
                <EditText
                    android:id="@+id/PhoneNumEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/EditTextStyleOne"
                    style="@style/EditTextNormalStyle"
                    android:layout_marginTop="4dp"
                    android:hint="@string/Lbl_Phone"
                    android:textSize="14sp"
                    android:inputType="number" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">
                <CheckBox
                    android:id="@+id/checkTermsOfService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center"
                    android:gravity="start|center"
                    android:text="@string/Lbl_I_agree_to_the"
                    android:textSize="13sp"
                    android:button="@drawable/shape_checkbox"
                    android:paddingStart="4dp" />
                <TextView
                    android:id="@+id/terms_of_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center"
                    android:text="@string/Terms_of_service"
                    android:textColor="@color/brand_green"
                    android:textSize="13sp"
                    android:paddingStart="4dp" />
            </LinearLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_marginTop="16dp"
                android:layout_height="50dp">
                <androidx.appcompat.widget.AppCompatButton
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:id="@+id/btnRegister"
                    android:textSize="17sp"
                    android:layout_gravity="center"
                    android:background="@drawable/round_button_pressed"
                    android:tag="false"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:text="@string/Lbl_Register"
                    android:forceDarkAllowed="false"
                    android:textColor="@color/gnt_white" />
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/gnt_white"
                    android:visibility="gone" />
            </FrameLayout>
            <TextView
                android:id="@+id/layout_already_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:text="@string/already_account"
                android:textColor="@color/brand_green"
                android:textSize="15sp" />
            <View
                android:layout_height="24dp"
                android:layout_width="match_parent" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
