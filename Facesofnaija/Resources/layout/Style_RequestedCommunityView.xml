<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorFill"
        android:padding="16dp">

        <TextView
            android:id="@+id/request_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSecondary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/request_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/request_name"
            android:layout_marginTop="4dp"
            android:textColor="?attr/colorOnSecondary"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/request_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/request_description"
            android:layout_marginTop="8dp"
            android:textColor="@color/gnt_gray"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/request_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/request_description"
            android:layout_toEndOf="@id/request_category"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/request_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_below="@id/request_description"
            android:layout_marginTop="8dp"
            android:textColor="@color/gnt_gray"
            android:textSize="11sp"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
