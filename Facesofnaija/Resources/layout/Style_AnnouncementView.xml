<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorFill"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:padding="16dp">

        <ImageView
            android:id="@+id/announcement_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/icon_announcement_vector"
            android:scaleType="centerCrop"
            android:padding="8dp"
            android:background="@drawable/circle_white"
            android:elevation="2dp"/>

        <TextView
            android:id="@+id/announcement_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignTop="@id/announcement_icon"
            android:textColor="@color/gnt_gray"
            android:textSize="11sp"
            android:gravity="end"/>

        <TextView
            android:id="@+id/announcement_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/announcement_icon"
            android:layout_toStartOf="@id/announcement_time"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:textColor="?attr/colorOnSecondary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/announcement_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/announcement_title"
            android:layout_toEndOf="@id/announcement_icon"
            android:layout_marginStart="12dp"
            android:layout_marginTop="6dp"
            android:textColor="?attr/colorOnSecondary"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
